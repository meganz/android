<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application tools:node="merge">
        <activity
            android:name=".appstate.MegaActivity"
            android:configChanges="screenSize"
            android:exported="true"
            android:theme="@style/Theme.Mega.Starting"
            android:windowSoftInputMode="adjustResize|stateAlwaysHidden"
            android:launchMode="singleTask"
            tools:node="replace" />
        <service
            android:name="mega.privacy.android.app.featuretoggle.FeatureFlagTileService"
            android:exported="true"
            android:icon="@drawable/ic_mega_logo"
            android:label="Feature Flag"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>
        <provider
            android:name=".providers.documentprovider.CloudDriveDocumentProvider"
            android:authorities="${cloudDriveDocumentProviderAuthority}"
            android:enabled="true"
            android:exported="true"
            android:grantUriPermissions="true"
            tools:replace="android:enabled"
            android:permission="android.permission.MANAGE_DOCUMENTS">
            <intent-filter>
                <action android:name="android.content.action.DOCUMENTS_PROVIDER" />
            </intent-filter>
        </provider>
        <activity
            android:name="mega.privacy.android.app.appstate.RerouteActivity"
            android:theme="@style/Theme.Mega.Starting"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".presentation.featureflag.FeatureFlagActivity"
            android:exported="false"
            android:label="@string/qa_feature_flag_title"
            android:launchMode="singleTop"
            android:parentActivityName=".main.ManagerActivity" />
        <activity
            android:name=".presentation.featureflag.FeatureFlagForQuickSettingsTileActivity"
            android:exported="false"
            android:label="@string/qa_feature_flag_title"
            android:launchMode="singleTop" >
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE_PREFERENCES"/>
            </intent-filter>
        </activity>

        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge"
            tools:replace="android:authorities">

            <meta-data
                android:name="mega.privacy.android.app.initializer.SyncMonitorInitializer"
                android:value="androidx.startup" />
        </provider>

    </application>

</manifest>
